GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
APP_SESSION_SECRET=replace-with-a-long-random-secret
API_PORT=8787
# Comma-separated origins allowed to call the API from browsers.
# Example: https://ultimate-box-score.pages.dev,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Optional rate-limit tuning (defaults shown)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=60
SYNC_RATE_LIMIT_WINDOW_MS=60000
SYNC_RATE_LIMIT_MAX=120

# PostgreSQL connection string
# Local: postgresql://localhost:5432/ulti_box_score
# Hosted (Railway, Render, Supabase): provided by the platform
DATABASE_URL=postgresql://localhost:5432/ulti_box_score
# Uncomment when using a hosted provider that requires SSL
# DATABASE_SSL=true
